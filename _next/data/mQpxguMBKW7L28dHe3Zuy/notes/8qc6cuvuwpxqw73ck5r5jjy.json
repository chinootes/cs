{"pageProps":{"note":{"id":"8qc6cuvuwpxqw73ck5r5jjy","title":"Static Method Can't be overridden","desc":"","updated":1708362866319,"created":1708357118086,"custom":{},"fname":"paradigm.oo.components.types.static.overriding","type":"note","vault":{"fsPath":".","selfContained":true,"name":"cs"},"contentHash":"4b33e5bc0e22cc128f6f6c8614e64fbd","links":[{"type":"wiki","from":{"fname":"paradigm.oo.components.types.static.overriding","id":"8qc6cuvuwpxqw73ck5r5jjy","vaultName":"cs"},"value":"paradigm.oo.components.types.static.method","position":{"start":{"line":3,"column":22,"offset":23},"end":{"line":3,"column":68,"offset":69},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"paradigm.oo.components.types.static.method"}},{"type":"wiki","from":{"fname":"paradigm.oo.components.types.static.overriding","id":"8qc6cuvuwpxqw73ck5r5jjy","vaultName":"cs"},"value":"paradigm.oo.components.types.static.overriding.fail","position":{"start":{"line":20,"column":6,"offset":319},"end":{"line":20,"column":61,"offset":374},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"paradigm.oo.components.types.static.overriding.fail"}},{"from":{"fname":"paradigm.oo.components.types.static.access using objects","id":"7azetbc1vf0zr2w38es3xj8","vaultName":"cs"},"type":"backlink","position":{"start":{"line":7,"column":109,"offset":498},"end":{"line":7,"column":159,"offset":548},"indent":[]},"value":"paradigm.oo.components.types.static.overriding"},{"from":{"fname":"paradigm.oo.components.types.static.method","id":"tz7zcxetfq1vhcgh95l1ote","vaultName":"cs"},"type":"backlink","position":{"start":{"line":9,"column":3,"offset":302},"end":{"line":9,"column":53,"offset":352},"indent":[]},"value":"paradigm.oo.components.types.static.overriding"}],"anchors":{},"children":["7jxqzwkqk645anv4qhlfei0"],"parent":"vklzkbrsrz6jzd5swlmq8yn","data":{}},"body":"<h1 id=\"static-method-cant-be-overridden\">Static Method Can't be overridden<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#static-method-cant-be-overridden\"></a></h1>\n<p>You can't override a <a href=\"/cs/notes/tz7zcxetfq1vhcgh95l1ote\">Static Method</a>.</p>\n<pre class=\"language-java\"><code class=\"language-java\"><span class=\"token comment\">//Can't do this -> Compile time error</span>\n<span class=\"token keyword\">class</span> <span class=\"token class-name\">Foo</span> <span class=\"token punctuation\">{</span>\n    <span class=\"token keyword\">public</span> <span class=\"token keyword\">static</span> <span class=\"token keyword\">void</span> <span class=\"token function\">method</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n        <span class=\"token class-name\">System</span><span class=\"token punctuation\">.</span>out<span class=\"token punctuation\">.</span><span class=\"token function\">println</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"in Foo\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n    <span class=\"token punctuation\">}</span>\n<span class=\"token punctuation\">}</span>\n \n<span class=\"token keyword\">class</span> <span class=\"token class-name\">Bar</span> <span class=\"token keyword\">extends</span> <span class=\"token class-name\">Foo</span> <span class=\"token punctuation\">{</span>\n    <span class=\"token keyword\">public</span> <span class=\"token keyword\">void</span> <span class=\"token function\">method</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n        <span class=\"token class-name\">System</span><span class=\"token punctuation\">.</span>out<span class=\"token punctuation\">.</span><span class=\"token function\">println</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"in Bar\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n    <span class=\"token punctuation\">}</span>\n<span class=\"token punctuation\">}</span>\n</code></pre>\n<p>Then <a href=\"/cs/notes/7jxqzwkqk645anv4qhlfei0\">Why compiler sometimes talks about overriding static methods?</a></p>\n<hr>\n<strong>Children</strong>\n<ol>\n<li><a href=\"/cs/notes/7jxqzwkqk645anv4qhlfei0\">Why compiler sometimes talks about overriding static methods?</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/cs/notes/7azetbc1vf0zr2w38es3xj8\">Accessing Static Members using Objects (cs)</a></li>\n<li><a href=\"/cs/notes/tz7zcxetfq1vhcgh95l1ote\">Static Method (cs)</a></li>\n</ul>","noteIndex":{"id":"7ncn3al6mmutkhgoesulce9","title":"Computer Science","desc":"","updated":1715103618849,"created":1713296516553,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","selfContained":true,"name":"cs"},"contentHash":"36faf26c6be438d4aed355d72b55a110","links":[{"type":"wiki","from":{"fname":"root","id":"7ncn3al6mmutkhgoesulce9","vaultName":"cs"},"value":"arch","position":{"start":{"line":6,"column":3,"offset":105},"end":{"line":6,"column":11,"offset":113},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"arch"}},{"type":"wiki","from":{"fname":"root","id":"7ncn3al6mmutkhgoesulce9","vaultName":"cs"},"value":"paradigm","position":{"start":{"line":11,"column":3,"offset":159},"end":{"line":11,"column":15,"offset":171},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"paradigm"}}],"anchors":{"references":{"type":"header","text":"References","value":"references","line":23,"column":0,"depth":2}},"children":["0xgibr34qhbv1edksyoxakk","t246wcci6dy9lnof7l1os4l","71sipcgr0pdqyxnmntvx28w","gwimvf1eb71o738641ky0ea","ruwap561ye9be5ty7kiz2ms","ruv2zbhnl7qd972ud1siis1","k8io31q2n5cfev77t4xizkv","fjhiirhj2woc1f5pldds72o","a9wfkku978mpxa3va5s48va","4593su4alwb8nzs8qxo41zf","oc9csyf7b83v8pi0gmxqghm","95sxewt1we6msblpzallwjl","twqoug8cl1mdnfw1o9xoohn","djfjitkydcq2sjgtuzlffq9","4ysb52