{"pageProps":{"note":{"id":"2flikwueaimsj1naahg6gn2","title":"HashMap","desc":"","updated":1713648663312,"created":1713642025198,"custom":{},"fname":"lang.java.lib.collection.map.hash","type":"note","vault":{"fsPath":".","selfContained":true,"name":"cs"},"contentHash":"37e8a620dc933fda2d7aed452a9703b4","links":[{"type":"wiki","from":{"fname":"lang.java.lib.collection.map.hash","id":"2flikwueaimsj1naahg6gn2","vaultName":"cs"},"value":"lang.java.lib.collection.map","position":{"start":{"line":3,"column":12,"offset":13},"end":{"line":3,"column":44,"offset":45},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"lang.java.lib.collection.map"}},{"type":"wiki","from":{"fname":"lang.java.lib.collection.map.hash","id":"2flikwueaimsj1naahg6gn2","vaultName":"cs"},"value":"lang.java.lib.collection.tags.thread safety.not safe","position":{"start":{"line":5,"column":1,"offset":47},"end":{"line":5,"column":57,"offset":103},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"lang.java.lib.collection.tags.thread safety.not safe"}},{"from":{"fname":"lang.java.lib.collection.cheatsheet","id":"fi3xznhjsf8ezkolih7torp","vaultName":"cs"},"type":"backlink","position":{"start":{"line":34,"column":5,"offset":1727},"end":{"line":34,"column":42,"offset":1764},"indent":[]},"value":"lang.java.lib.collection.map.hash"},{"from":{"fname":"lang.java.lib.collection.map","id":"bsk6mro2a2qy52s1c3jkvqu","vaultName":"cs"},"type":"backlink","position":{"start":{"line":9,"column":4,"offset":386},"end":{"line":9,"column":41,"offset":423},"indent":[]},"value":"lang.java.lib.collection.map.hash"},{"from":{"fname":"lang.java.lib.collection.map","id":"bsk6mro2a2qy52s1c3jkvqu","vaultName":"cs"},"type":"backlink","position":{"start":{"line":21,"column":3,"offset":1360},"end":{"line":21,"column":40,"offset":1397},"indent":[]},"value":"lang.java.lib.collection.map.hash"}],"anchors":{"initialization":{"type":"header","text":"Initialization","value":"initialization","line":13,"column":0,"depth":2},"methods":{"type":"header","text":"Methods","value":"methods","line":25,"column":0,"depth":2},"implementation":{"type":"header","text":"Implementation","value":"implementation","line":36,"column":0,"depth":2},"references":{"type":"header","text":"References","value":"references","line":67,"column":0,"depth":2}},"children":[],"parent":"bsk6mro2a2qy52s1c3jkvqu","data":{}},"body":"<h1 id=\"hashmap\">HashMap<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#hashmap\"></a></h1>\n<p>implements <a href=\"/cs/notes/bsk6mro2a2qy52s1c3jkvqu\">Map</a></p>\n<p><a href=\"/cs/notes/t0ciw781n1840e7fm3o2ux4\">Not Thread Safe</a></p>\n<h2 id=\"initialization\">Initialization<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#initialization\"></a></h2>\n<pre class=\"language-java\"><code class=\"language-java\"><span class=\"token class-name\">Map</span> map <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">HashMap</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n</code></pre>\n<p>or</p>\n<pre class=\"language-java\"><code class=\"language-java\"><span class=\"token class-name\">Map</span><span class=\"token generics\"><span class=\"token punctuation\">&#x3C;</span><span class=\"token class-name\">String</span><span class=\"token punctuation\">,</span> <span class=\"token class-name\">String</span><span class=\"token punctuation\">></span></span> map <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">HashMap</span><span class=\"token generics\"><span class=\"token punctuation\">&#x3C;</span><span class=\"token class-name\">String</span><span class=\"token punctuation\">,</span> <span class=\"token class-name\">String</span><span class=\"token punctuation\">></span></span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n</code></pre>\n<h2 id=\"methods\">Methods<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#methods\"></a></h2>\n<ul>\n<li><code>map.put(\"key\", \"value\");</code></li>\n<li><code>map.get(\"key\");</code> → value</li>\n<li><code>keySet()</code> → Set of keys</li>\n</ul>\n<p>What happens when Repeating/duplicate keys ⇒ value gets replaced</p>\n<ul>\n<li>Fixed Order insertion → Linked HashMap</li>\n<li>Sorting Order → Tree HashMap</li>\n</ul>\n<h2 id=\"implementation\">Implementation<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#implementation\"></a></h2>\n<pre class=\"language-java\"><code class=\"language-java\"><span class=\"token class-name\">HashMap</span> <span class=\"token generics\"><span class=\"token punctuation\">&#x3C;</span><span class=\"token class-name\">K</span><span class=\"token punctuation\">,</span><span class=\"token class-name\">V</span><span class=\"token punctuation\">></span></span> <span class=\"token keyword\">implements</span> <span class=\"token class-name\">Map</span><span class=\"token generics\"><span class=\"token punctuation\">&#x3C;</span><span class=\"token class-name\">K</span><span class=\"token punctuation\">,</span><span class=\"token class-name\">V</span><span class=\"token punctuation\">></span></span>\n<span class=\"token punctuation\">{</span>\n<span class=\"token class-name\">Entry</span> <span class=\"token generics\"><span class=\"token punctuation\">&#x3C;</span><span class=\"token class-name\">K</span><span class=\"token punctuation\">,</span><span class=\"token class-name\">V</span><span class=\"token punctuation\">></span></span> <span class=\"token punctuation\">{</span><span class=\"token punctuation\">}</span> <span class=\"token comment\">//Inner class</span>\n<span class=\"token class-name\">Entry</span> next<span class=\"token punctuation\">;</span> <span class=\"token comment\">//reference to another entry to store entries like linked lists</span>\n\n<span class=\"token keyword\">int</span> hash<span class=\"token punctuation\">;</span> <span class=\"token comment\">//Hashvalue of key to avoid calculating everytime its  needed</span>\n<span class=\"token punctuation\">}</span>\n</code></pre>\n<ul>\n<li>\n<p>Initial Capacity</p>\n<p>  16 (Array of 0-15)</p>\n</li>\n<li>\n<p>Load factor - After the load factor (percentage) is reached, the capacity automatically increases</p>\n<p>  0.75</p>\n<ul>\n<li>So when the array is filled more than 75%, the table size doubles to 32.</li>\n<li>The hashtable is rehashed (Internal data structures are rebuit)</li>\n</ul>\n</li>\n<li>\n<p>Java 8 improvement</p>\n<p>  When the number of nodes in a HashMap reaches the TREEIFY_THRESHOLD, the nodes are converted to TreeNode. Basically, from linked list to a balanced tree. This improves the worst case performance from O(n) to O(log n). After the HashMap becomes small due to removal or resizing, TreeNodes are converted back to nodes.</p>\n</li>\n<li>\n<p>HashMap Bucket Resizing Overhead</p>\n<p>  You should create HashMap with initial capacity close to your expected volume. If its too small, and the load is in millions, whenever the bucket will reach its load factor it will resize and rehash → which is a very costly operation. Also, make sure to use full capacity else a lot of memory of unused blocks will go wasted.\n</p>\n</li>\n</ul>\n<h2 id=\"references\">References<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#references\"></a></h2>\n<ul>\n<li><a href=\"https://www.youtube.com/watch?v=c3RVW3KGIIE\">How HashMap works in Java? With Animation!! whats new in java8 tutorial</a></li>\n<li><a href=\"https://dzone.com/articles/java8-hashmap-implementation-and-performance\">Java 8 HashMap Implementation and Performance - DZone Java</a></li>\n</ul>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/cs/notes/fi3xznhjsf8ezkolih7torp\">Collection Frameworks Cheatsheet (cs)</a></li>\n<li><a href=\"/cs/notes/bsk6mro2a2qy52s1c3jkvqu\">Map (cs)</a></li>\n</ul>","noteIndex":{"id":"7ncn3al6mmutkhgoesulce9","title":"Computer Science","desc":"","updated":1715103618849,"created":1713296516553,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","selfContained":true,"name":"cs"},"contentHash":"36faf26c6be438d4aed355d72b55a110","links":[{"type":"wiki","from":{"fname":"root","id":"7ncn3al6mmutkhgoesulce9","vaultName":"cs"},"value":"arch","position":{"start":{"line":6,"column":3,"offset":105},"end":{"line":6,"column":11,"offset":113},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"arch"}},{"type":"wiki","from":{"fname":"root","id":"7ncn3al6mmutkhgoesulce9","vaultName":"cs"},"value":"paradigm","position":{"start":{"line":11,"column":3,"offset":159},"end":{"line":11,"column":15,"offset":171},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"paradigm"}}],"anchors":{"references":{"type":"header","text":"References","value":"references","line":23,"column":0,"depth":2}},"children":["0xgibr34qhbv1edksyoxakk","t246wcci6dy9lnof7l1os4l","71sipcgr0pdqyxnmntvx28w","gwimvf1eb71o738641ky0ea","ruwap561ye9be5ty7kiz2ms","ruv2zbhnl7qd972ud1siis1","k8io31q2n5cfev77t4xizkv","fjhiirhj2woc1f5pldds72o","a9wfkku978mpxa3va5s48va","4593su4alwb8nzs8qxo41zf","oc9csyf7b83v8pi0gmxqghm","95sxewt1we6msblpzallwjl","twqoug8cl1mdnfw1o9xoohn","djfjitkydcq2sjgtuzlffq9","4ysb52nvzx8s5oljcj2lktp","k6b5g1sd97mqgl2n0becqd2"],"parent":null,"data":{},"body":"\n\nThese notes are arranged into the below topics:\n\n- AI (Sorry this is on the top, list is alphabetic)\n- [[arch]]\n- Data\n- Execution\n- Languages\n- Semantics\n- [[paradigm]]\n- Philosophy\n- Dev\n- Tools\n- Type Theory\n\n## References\n\n- Hierarchy inpiration - [Map of Computer Science](https://www.flickr.com/photos/95869671@N08/36231833334/in/photostream/lightbox/)"},"collectionChildren":null,"customHeadContent":null,"config":{"version":5,"dev":{"enablePreviewV2":true,"enableSelfCon