{"pageProps":{"note":{"id":"3c00rfpbb517etfmlnymxe5","title":"Request-Response","desc":"","updated":1708751295131,"created":1708751256620,"custom":{},"fname":"arch.concepts.pattern.messaging.request-response","type":"note","vault":{"fsPath":".","selfContained":true,"name":"cs"},"contentHash":"8cbe07e03099a2cae8e5089d7fe99e3e","links":[{"type":"wiki","from":{"fname":"arch.concepts.pattern.messaging.request-response","id":"3c00rfpbb517etfmlnymxe5","vaultName":"cs"},"value":"arch.concepts.pattern.messaging","position":{"start":{"line":2,"column":9,"offset":9},"end":{"line":2,"column":44,"offset":44},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"arch.concepts.pattern.messaging"}}],"anchors":{"model":{"type":"header","text":"Model","value":"model","line":10,"column":0,"depth":2},"anatomy":{"type":"header","text":"Anatomy","value":"anatomy","line":18,"column":0,"depth":2},"where-is-it-used":{"type":"header","text":"Where is it used?","value":"where-is-it-used","line":24,"column":0,"depth":2},"where-it-doesnt-work-well":{"type":"header","text":"Where it doesn't work well?","value":"where-it-doesnt-work-well","line":31,"column":0,"depth":2}},"children":[],"parent":"a7crvbexqg9euwget6u990s","data":{}},"body":"<h1 id=\"request-response\">Request-Response<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#request-response\"></a></h1>\n<p>It is a <a href=\"/cs/notes/a7crvbexqg9euwget6u990s\">Messaging Pattern</a>.</p>\n<h2 id=\"model\">Model<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#model\"></a></h2>\n<ul>\n<li>Client sends a request</li>\n<li>Server parses the request: Where does a request begin and end?</li>\n<li>Server processes the request: Example, Deserializing JSON and then processing.</li>\n<li>Server sends a response</li>\n<li>Client parses the response and consume</li>\n</ul>\n<h2 id=\"anatomy\">Anatomy<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#anatomy\"></a></h2>\n<ul>\n<li>Client and server need to define and agree upon the request/response structure.</li>\n<li>Request/response has a boundary</li>\n<li>Defined by protocol and message format.</li>\n</ul>\n<h2 id=\"where-is-it-used\">Where is it used?<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#where-is-it-used\"></a></h2>\n<ul>\n<li>Web, HTTP, DNS, SSH.</li>\n<li>Remote Procedure Call (RPC)</li>\n<li>SQL and database protocols</li>\n<li>APIs (REST/SOAP/GraphQL)</li>\n</ul>\n<h2 id=\"where-it-doesnt-work-well\">Where it doesn't work well?<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#where-it-doesnt-work-well\"></a></h2>\n<ul>\n<li>Notification Service</li>\n<li>Chat Applications</li>\n<li>Very Long requests - What if client disconnects?</li>\n</ul>","noteIndex":{"id":"7ncn3al6mmutkhgoesulce9","title":"Computer Science","desc":"","updated":1715103618849,"created":1713296516553,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","selfContained":true,"name":"cs"},"contentHash":"36faf26c6be438d4aed355d72b55a110","links":[{"type":"wiki","from":{"fname":"root","id":"7ncn3al6mmutkhgoesulce9","vaultName":"cs"},"value":"arch","position":{"start":{"line":6,"column":3,"offset":105},"end":{"line":6,"column":11,"offset":113},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"arch"}},{"type":"wiki","from":{"fname":"root","id":"7ncn3al6mmutkhgoesulce9","vaultName":"cs"},"value":"paradigm","position":{"start":{"line":11,"column":3,"offset":159},"end":{"line":11,"column":15,"offset":171},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"paradigm"}}],"anchors":{"references":{"type":"header","text":"References","value":"references","line":23,"column":0,"depth":2}},"children":["0xgibr34qhbv1edksyoxakk","t246wcci6dy9lnof7l1os4l","71sipcgr0pdqyxnmntvx28w","gwimvf1eb71o738641ky0ea","ruwap561ye9be5ty7kiz2ms","ruv2zbhnl7qd972ud1siis1","k8io31q2n5cfev77t4xizkv","fjhiirhj2woc1f5pldds72o","a9wfkku978mpxa3va5s48va","4593su4alwb8nzs