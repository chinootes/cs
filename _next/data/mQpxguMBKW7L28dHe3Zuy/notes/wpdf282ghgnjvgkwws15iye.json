nc.principles.composition","position":{"start":{"line":13,"column":4,"offset":515},"end":{"line":13,"column":44,"offset":555},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"paradigm.func.principles.composition"}},{"type":"wiki","from":{"fname":"paradigm.func","id":"wpdf282ghgnjvgkwws15iye","vaultName":"cs"},"value":"paradigm.func.principles.recursion","position":{"start":{"line":14,"column":4,"offset":559},"end":{"line":14,"column":42,"offset":597},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"paradigm.func.principles.recursion"}},{"type":"wiki","from":{"fname":"paradigm.func","id":"wpdf282ghgnjvgkwws15iye","vaultName":"cs"},"value":"paradigm.func.principles.lazy","position":{"start":{"line":15,"column":4,"offset":601},"end":{"line":15,"column":37,"offset":634},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"paradigm.func.principles.lazy"}}],"anchors":{"foundational-principles":{"type":"header","text":"Foundational Principles","value":"foundational-principles","line":16,"column":0,"depth":2},"references":{"type":"header","text":"References","value":"references","line":23,"column":0,"depth":2}},"children":["5dt6hl1hqg2xt16juops23d","fmbgnm0y9t8iic2ad7pb79v"],"parent":"71sipcgr0pdqyxnmntvx28w","data":{},"schema":{"schemaId":"paradigm","moduleId":"paradigm"}},"body":"<h1 id=\"functional-programming\">Functional Programming<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#functional-programming\"></a></h1>\n<blockquote>\n<p>Computations are by nature evaluation of mathematical functions.</p>\n</blockquote>\n<ul>\n<li>Based on the above foundational statement.</li>\n<li><a href=\"/cs/notes/63rgy8qmhxp9sjxvy63xr5q\">Declarative</a> paradigm.</li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">programming.function (Private)</a>s are first-class citizens. They can be assigned to variables and passed as an argument.</li>\n</ul>\n<p>Functional programming implements concepts from Mathematical <a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">analysis.func (Private)</a>tions in a way which avoid <a class=\"color-tag\" style=\"--tag-color: #4b6113;\" href=\"/cs/notes/f1kub79hm4j51ojdga0czti\">#surprises</a> and promotes concise and readable code.</p>\n<h2 id=\"foundational-principles\">Foundational Principles<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#foundational-principles\"></a></h2>\n<ol>\n<li><a href=\"/cs/notes/gxuhph8erusooz1thpwp9xp\">Immutability</a></li>\n<li><a href=\"/cs/notes/u1r7f2489mfxxpd1lxi7hou\">Function Composition</a></li>\n<li><a href=\"/cs/notes/6vu1t1tzeb0dfbt1t4cnick\">Recursion</a></li>\n<li><a href=\"/cs/notes/8831hyai4z9h1jgtjhvkra2\">Lazy Evaluation</a></li>\n</ol>\n<h2 id=\"references\">References<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#references\"></a></h2>\n<ul>\n<li><a href=\"https://youtu.be/JQDRCTa32jY?si=73tfB25rqgdqUhbw\">Why Functional Programming Matters • John Hughes • YOW! 2017</a></li>\n</ul>","noteIndex":{"id":"7ncn3al6mmutkhgoesulce9","title":"Computer Science","desc":"","updated":1715103618849,"created":1713296516553,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","selfContained":true,"name":"cs"},"contentHash":"36faf26c6be438d4aed355d72b55a110","links":[{"type":"wiki","from":{"fname":"root","id":"7ncn3al6mmutkhgoesulce9","vaultName":"cs"},"value":"arch","position":{"start":{"line":6,"column":3,"offset":105},"end":{"line":6,"column":11,"offset":113},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"arch"}},{"type":"wiki","from":{"fname":"root","id":"7ncn3al6mmutkhgoesulce9","vaultName":"cs"},"value":"paradigm","position":{"start":{"line":11,"column":3,"offset":159},"end":{"line":11,"column":15,"offset":171},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"paradigm"}}],"anchor