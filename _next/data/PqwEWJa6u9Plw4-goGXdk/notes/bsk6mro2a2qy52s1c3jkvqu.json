a2qy52s1c3jkvqu","vaultName":"cs"},"value":"lang.java.lib.collection.map.hashtable","position":{"start":{"line":25,"column":3,"offset":1538},"end":{"line":25,"column":45,"offset":1580},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"lang.java.lib.collection.map.hashtable"}},{"from":{"fname":"lang.java.lib.collection.cheatsheet","id":"fi3xznhjsf8ezkolih7torp","vaultName":"cs"},"type":"backlink","position":{"start":{"line":33,"column":3,"offset":1686},"end":{"line":33,"column":35,"offset":1718},"indent":[]},"value":"lang.java.lib.collection.map"},{"from":{"fname":"lang.java.lib.collection.map.hash","id":"2flikwueaimsj1naahg6gn2","vaultName":"cs"},"type":"backlink","position":{"start":{"line":3,"column":12,"offset":13},"end":{"line":3,"column":44,"offset":45},"indent":[]},"value":"lang.java.lib.collection.map"},{"from":{"fname":"lang.java.lib.collection.map.hashtable","id":"gu1ozy25u42r56u3nsuucww","vaultName":"cs"},"type":"backlink","position":{"start":{"line":2,"column":12,"offset":12},"end":{"line":2,"column":44,"offset":44},"indent":[]},"value":"lang.java.lib.collection.map"},{"from":{"fname":"lang.java.lib.collection.map.sorted","id":"4cyorq5w2fbmxmys9kowugd","vaultName":"cs"},"type":"backlink","position":{"start":{"line":4,"column":12,"offset":25},"end":{"line":4,"column":44,"offset":57},"indent":[]},"value":"lang.java.lib.collection.map"}],"anchors":{"vs":{"type":"header","text":"vs","value":"vs","line":15,"column":0,"depth":2}},"children":["2flikwueaimsj1naahg6gn2","gu1ozy25u42r56u3nsuucww","wlftnmp7thzpvca4ocbbxsf","4cyorq5w2fbmxmys9kowugd","b63mj2mkjzvz4ridttd0ge9"],"parent":"dkdtvct3q6f8lggmoqrqf43","data":{}},"body":"<h1 id=\"map\">Map<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#map\"></a></h1>\n<ul>\n<li>To represent group of objects as key value pairs</li>\n<li>NOT a child interface of <a href=\"/cs/notes/rpb0p7ld8g30mdscf1r32re\">Collection Interface</a></li>\n<li>Therefore, strictly speaking, <a href=\"/cs/notes/rpb0p7ld8g30mdscf1r32re\">Collection Interface</a> is NOT root interface of Collection framework</li>\n<li>Duplicates\n<ul>\n<li>Keys - <a href=\"/cs/notes/erabl4efwn49ad1hyh9q9xo\">Duplicates - NOT Allowed</a></li>\n<li>Values - <a href=\"/cs/notes/esvk57cujir0xgnugroobcg\">Duplicates - Allowed</a></li>\n</ul>\n</li>\n</ul>\n<h2 id=\"hashmap-vs-hashtable\"><a href=\"/cs/notes/2flikwueaimsj1naahg6gn2\">HashMap</a> vs <a href=\"/cs/notes/gu1ozy25u42r56u3nsuucww\">Hashtable</a><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#hashmap-vs-hashtable\"></a></h2>\n<div class=\"table-responsive\">\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<table><thead><tr><th></th><th>HashMap</th><th>Hashtable</th></tr></thead><tbody><tr><td>Introduced in</td><td>1.2</td><td>1.0</td></tr><tr><td>Thread Safety</td><td>Not thread safe (not synchronized) => works with single thread</td><td>Thread safe (synchronized) => works with multiple threads</td></tr><tr><td>Speed</td><td>Faster</td><td>Slower</td></tr><tr><td>Null key</td><td>One null key allowed</td><td>Null key not allowed</td></tr></tbody></table></div>\n<p>Child classes/interfaces:</p>\n<ul>\n<li><a href=\"/cs/notes/2flikwueaimsj1naahg6gn2\">HashMap</a></li>\n<li><a href=\"/cs/notes/b63mj2mkjzvz4ridttd0ge9\">WeakHashMap</a></li>\n<li><a href=\"/cs/notes/wlftnmp7thzpvca4ocbbxsf\">IdentityHashMap</a></li>\n<li><a href=\"/cs/notes/4cyorq5w2fbmxmys9kowugd\">SortedMap</a> (I)</li>\n<li><a href=\"/cs/notes/gu1ozy25u42r56u3nsuucww\">Hashtable</a></li>\n</ul>\n<hr>\n<strong>Children</strong>\n<ol>\n<li><a href=\"/cs/notes/2flikwueaimsj1naahg6gn2\">HashMap</a></li>\n<li><a href=\"/cs/notes/gu1ozy25u42r56u3nsuucww\">Hashtable</a></li>\n<li><a href=\"/cs/notes/wlftnmp7thzpvca4ocbbxsf\">IdentityHashMap</a></li>\n<li><a href=\"/cs/notes/4cyorq5w2fbmxmys9kowugd\">SortedMap</a></li>\n<li><a href=\"/cs/notes/b63mj2mkjzvz4ridttd0ge9\">WeakHashMap</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/cs/notes/fi3xznhjsf8ezkolih7torp\">Collection Frameworks Cheatsheet (cs)</a></li>\n<li><a href=\"/cs/notes/2flikwueaimsj1naahg6gn2\">HashMap (cs)</a></li>\n<li><a href=\"/cs/notes/gu1ozy25u42r56u3nsuucww\">Hashtable (cs)</a></li>\n<li><a href=\"/cs/notes/4cyorq5w2fbmxmys9kowugd\">SortedMap (cs)</a></li>\n</ul>","noteIndex":{"id":"7ncn3al6mmutkhgoesulce9","title":"Computer Science","desc":"","updated":1715103618849,"created":1713296516553,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","selfContained":true,"name":"cs"},"contentHash":"36faf26c6be438d4aed355d72b55a110","links":[{"type":"wiki","from":{"fname":"root","id":"7ncn3al6mmutkhgoesulce9","vaultName":"cs"},"value":"arch","position":{"start":{"line":6,"column":3,"offset":105},"end":{"line":6,"column":11,"offset":113},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"arch"}},{"type":"wiki","from":{"fname":"root","id":"7ncn3al6mmutkhgoesulce9","vaultName":"cs"},"value":"paradigm","position":{"start":{"line":11,"column":3,"offset":159},"end":{"line":11,"column":15,"offset":171},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"paradigm"}}],"anchors":{"references":{"type":"header","text":"References","value":"references","line":23,"column":0,"depth":2}},"children":["0xgibr34qhbv1edksyoxakk","t246wcci6dy9lnof7l1os4l","71sipcgr0pdqyxnmntvx28w","6k8qk8m6zofpfla0wr8eajn","szmkrtr9ezx1kg3mzcamb7m","a6m88ijp6ij9aam2ose0k6j","7t5m5bvvkqqmexze4ymednf","4bgqfqpix52j5ek9oawj3lw","ng2w78j1rxy1prvsi6zc9j3","q1uj4uy5892ahhlgrn1wi7m","qnetoavqu273jl4iovqtk76","qanoka2zolegyqtrlis4sg2","nsbtaj4zu6fmgjuooy55mbx","uc1prffatcsbivlbj2yud2i","azqmz08s69usdskj1a7v94c","v3e3a8biac8damddtjrn7az","qqb74o6z75mxkm5ygg7d6h2"],"parent":null,"data":{},"body":"\n\nThese notes are arranged into the below topics:\n\n- AI (Sorry this is on the top, list is alphabetic)\n- [[arch]]\n- Data\n- Execution\n- Languages\n- Semantics\n- [[paradigm]]\n- Philosophy\n- Dev\n- Tools\n- Type Theory\n\n##